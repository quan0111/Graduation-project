generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String?   

  fullName  String?
  phone     String?
  avatarUrl String?

  provider   String?   
  providerId String?   

  role      UserRole @default(CUSTOMER)
  isActive  Boolean  @default(true)
  addresses                  Address[]
  shops                      Shop?
  orders                     Order[]
  reviews                    Review[]
  reviewReplies              ReviewReply[]
  wishlists                  Wishlist[]
  couponRedemptions          CouponRedemption[]
  behaviors                  UserBehavior[]
  carts                      Cart?
  recommendations            Recommendation[]
  notifications              Notification[]
  refreshTokens              RefreshToken[]
  shopFollowers              ShopFollower[]
  bannerTrackings            BannerTracking[]
  sellerApplications         SellerApplication[] @relation("SellerApplicationUser")
  reviewedSellerApplications SellerApplication[] @relation("SellerApplicationReviewedBy")
  returnRequests             ReturnRequest[]     @relation("ReturnRequestUser")
  reviewedReturns            ReturnRequest[]     @relation("ReturnReviewedBy")
  createdBanners             Banner[]            @relation("BannerCreatedBy")
  auditLogsAsActor           AuditLog[]          @relation("AuditActor")
  auditLogsAsTarget          AuditLog[]          @relation("AuditTargetUser")
  inventoryLedgers           InventoryLedger[]   @relation("InventoryActor")
  supportTickets             SupportTicket[]     @relation("SupportTicketUser")
  assignedSupportTickets     SupportTicket[]     @relation("SupportTicketAssignee")
  supportMessages            SupportMessage[]    @relation("SupportMessageSender")
  securityIncidents          SecurityIncident[]  @relation("SecurityIncidentUser")
  resolvedSecurityIncidents  SecurityIncident[]  @relation("SecurityIncidentResolvedBy")
  moderationCasesAsSeller    ProductModerationCase[] @relation("ProductModerationSeller")
  reviewedModerationCases    ProductModerationCase[] @relation("ProductModerationReviewer")
  reviewedPayouts            SellerPayout[]      @relation("SellerPayoutReviewedBy")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  @@index([email])
  @@unique([provider, providerId]) 
}

enum UserRole {
  ADMIN
  SELLER
  CUSTOMER
}

model Address {
  id          Int         @id @default(autoincrement())
  userId      Int
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String
  phone       String
  addressLine String
  ward        String?
  district    String
  province    String
  country     String      @default("Vietnam")
  postalCode  String?
  isDefault   Boolean     @default(false)
  type        AddressType @default(HOME)

  orders Order[] @relation("ShippingAddress")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
}

enum AddressType {
  HOME
  OFFICE
  OTHER
}

model Shop {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String? @unique
  description String?
  avatarUrl   String?
  ownerId     Int     @unique
  isActive    Boolean @default(true)
  owner       User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  followers        ShopFollower[]
  products         Product[]
  flashSaleItems   FlashSaleItem[]
  orderitemss      OrderItem[]
  payouts          SellerPayout[]
  commissions      PlatformCommission[]
  commissionConfig ShopCommissionConfig?
  coupons          Coupon[]
  cartitems        CartItem[]
  inventoryLedgers InventoryLedger[]
  supportTickets   SupportTicket[]
  orderPackages    OrderShopPackage[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
  @@index([ownerId])
  @@index([isActive])
}

model Category {
  id               Int                       @id @default(autoincrement())
  name             String
  slug             String?                   @unique
  parentId         Int?
  parent           Category?                 @relation("CategoryTree", fields: [parentId], references: [id])
  children         Category[]                @relation("CategoryTree")
  products         Product[]
  commissionConfig CategoryCommissionConfig?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
  @@index([parentId])
}

enum ProductStatus {
  DRAFT
  APPROVAL
  ACTIVE
  OUT_OF_STOCK
  BANNED
  REJECT
}

model Product {
  id          Int           @id @default(autoincrement())
  name        String
  slug        String?       @unique
  description String?
  price       Float
  shopId      Int
  categoryId  Int
  status      ProductStatus @default(DRAFT)

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  variants   ProductVariant[]
  images     ProductImage[]
  reviews    Review[]
  wishlistedBy Wishlist[]
  flashSaleItems FlashSaleItem[]
  couponTargets CouponProductTarget[]
  orderItems OrderItem[]
  behaviors  UserBehavior[]
  cartItems  CartItem[]
  attributes ProductAttribute[]
  tags       Tag[]              @relation("ProductTags")
  moderationCases ProductModerationCase[]
  inventoryLedgers InventoryLedger[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
  @@index([categoryId])
  @@index([shopId])
  @@index([name])
}

model ProductVariant {
  id        Int     @id @default(autoincrement())
  sku       String? @unique
  name      String
  stock     Int
  weight    Float?
  productId Int
  price     Float

  product    Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  images     VariantImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]
  inventoryLedgers InventoryLedger[]
  flashSaleItems FlashSaleItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String
  position  Int     @default(0)
  isPrimary Boolean @default(false)
  productId Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model VariantImage {
  id        Int    @id @default(autoincrement())
  url       String
  position  Int    @default(0)
  variantId Int

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model Cart {
  id     Int @id @default(autoincrement())
  userId Int @unique

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        Int  @id @default(autoincrement())
  cartId    Int
  productId Int
  variantId Int?
  shopId    Int
  quantity  Int

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  shop    Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  @@unique([cartId, productId, variantId,shopId])
}

model Order {
  id             Int         @id @default(autoincrement())
  userId         Int
  status         OrderStatus @default(PENDING)
  subtotal       Float
  shippingFee    Float       @default(0)
  shippingMethod String?
  discountAmount Float       @default(0)
  totalAmount    Float

  shippingAddressId Int?
  couponId          Int?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingAddress Address? @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  coupon          Coupon?  @relation(fields: [couponId], references: [id])
  couponRedemptions CouponRedemption[]

  items          OrderItem[]
  payment        Payment?
  shipment       Shipment?
  shipmentEvents ShipmentEvent[]
  cancellation   OrderCancellation?
  returnRequests ReturnRequest[]
  commissions    PlatformCommission[]
  inventoryLedgers InventoryLedger[]
  paymentEvents  PaymentEvent[]
  supportTickets SupportTicket[]
  packages       OrderShopPackage[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

enum OrderStatus {
  PENDING
  PENDING_PAYMENT
  CONFIRMED
  PAID
  PAYMENT_FAILED
  PAYMENT_EXPIRED
  PROCESSING
  READY_TO_SHIP
  SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCEL_REQUESTED
  CANCELLED_BY_CUSTOMER
  CANCELLED_BY_SELLER
  CANCEL_REJECTED
  CANCEL_APPROVED
  CANCELLED
  DELIVERY_FAILED
  RETURN_TO_SENDER
  RETURN_REQUESTED
  RETURNED
}

model OrderShopPackage {
  id             Int         @id @default(autoincrement())
  orderId        Int
  shopId         Int
  status         OrderStatus @default(PENDING)
  carrier        String?
  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop  Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orderId, shopId])
  @@index([orderId])
  @@index([shopId])
  @@index([status])
}

model OrderItem {
  id           Int     @id @default(autoincrement())
  shopId       Int
  orderId      Int
  productId    Int
  variantId    Int?
  quantity     Int
  price        Float
  productName  String
  variantName  String?
  productImage String?

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
  shop    Shop            @relation(fields: [shopId], references:[id])
  returnItems ReturnItem[]
  commissions PlatformCommission[]

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@index([shopId])
}

model Payment {
  id              Int           @id @default(autoincrement())
  orderId         Int           @unique
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Float?
  providerOrderId String?       @unique
  requestId       String?
  transactionId   String?
  paymentUrl      String?
  qrCodeUrl       String?
  deeplink        String?
  providerMessage String?
  providerResponse Json?
  rawCallback     Json?
  paidAt          DateTime?

  order  Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events PaymentEvent[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([method])
  @@index([status])
}

enum PaymentMethod {
  COD
  VNPAY
  MOMO
  STRIPE
}

enum PaymentStatus {
  PENDING
  PENDING_PAYMENT
  SUCCESS
  PAYMENT_SUCCESS
  FAILED
  PAYMENT_FAILED
  PAYMENT_EXPIRED
  REFUNDING
  REFUNDED
  REFUND_FAILED
  PARTIALLY_REFUNDED
}

enum PaymentEventType {
  CREATED
  RETRY_CREATED
  CALLBACK_RECEIVED
  STATUS_SYNCED
  MANUAL_UPDATE
}

model PaymentEvent {
  id              Int              @id @default(autoincrement())
  paymentId       Int?
  orderId         Int?
  provider        String?
  eventType       PaymentEventType
  status          PaymentStatus?
  providerOrderId String?
  requestId       String?
  transactionId   String?
  message         String?
  retryCount      Int              @default(0)
  payload         Json?

  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  order   Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([paymentId])
  @@index([orderId])
  @@index([providerOrderId])
  @@index([eventType])
  @@index([createdAt(sort: Desc)])
}

model Coupon {
  id               Int          @id @default(autoincrement())
  code             String       @unique
  description      String?
  scope            String       @default("ORDER")
  discountType     DiscountType
  discountValue    Float
  minOrderAmount   Float?
  maxDiscount      Float?
  usageLimit       Int?
  usedCount        Int          @default(0)
  validFrom        DateTime?
  validUntil       DateTime?
  isActive         Boolean      @default(true)
  applicableShopId Int?
  applicableCategoryId Int?
  applicableProductId Int?
  applicableShop   Shop?        @relation(fields: [applicableShopId], references: [id], onDelete: SetNull)
  productTargets   CouponProductTarget[]
  orders           Order[]
  redemptions      CouponRedemption[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  usageLimitPerUser Int?

  @@index([scope])
  @@index([applicableShopId])
  @@index([applicableCategoryId])
  @@index([applicableProductId])
}

model CouponProductTarget {
  couponId  Int
  productId Int
  coupon    Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([couponId, productId])
  @@index([productId])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model Review {
  id                 Int     @id @default(autoincrement())
  rating             Int
  comment            String?
  isVerifiedPurchase Boolean @default(false)
  userId             Int
  productId          Int

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  media   ReviewMedia[]
  replies ReviewReply[]

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([productId])
  @@index([userId, productId])
}

model ReviewMedia {
  id        Int             @id @default(autoincrement())
  reviewId  Int
  url       String
  type      ReviewMediaType @default(IMAGE)
  position  Int             @default(0)

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([reviewId])
}

enum ReviewMediaType {
  IMAGE
  VIDEO
}

model ReviewReply {
  id        Int       @id @default(autoincrement())
  reviewId  Int
  sellerId  Int
  content   String
  deletedAt DateTime?

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  seller User   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewId])
  @@index([sellerId])
}

model Wishlist {
  id        Int @id @default(autoincrement())
  userId    Int
  productId Int

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([productId])
}

model UserBehavior {
  id        Int          @id @default(autoincrement())
  userId    Int
  productId Int
  action    BehaviorType
  sessionId String?
  duration  Int?
  metadata  Json?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, action])
  @@index([productId])
}

enum BehaviorType {
  VIEW
  CLICK
  ADD_TO_CART
  PURCHASE
}

model ProductAttribute {
  id        Int       @id @default(autoincrement())
  productId Int
  key       String
  value     String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, key])
}

model Tag {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[] @relation("ProductTags")
}

model Recommendation {
  id          Int      @id @default(autoincrement())
  userId      Int
  sessionId   String?
  recommended Json
  algorithm   String?
  timestamp   DateTime @default(now())
  feedback    Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp(sort: Desc)])
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

model AuditLog {
  id           Int           @id @default(autoincrement())
  actorId      Int?
  targetUserId Int?
  action       String
  entityType   String
  entityId     Int?
  severity     AuditSeverity @default(INFO)
  ipAddress    String?
  userAgent    String?
  metadata     Json?

  actor     User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetUser User? @relation("AuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([actorId, createdAt(sort: Desc)])
  @@index([targetUserId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([action])
  @@index([severity])
}

enum SecurityIncidentStatus {
  OPEN
  RESOLVED
  DISMISSED
}

model SecurityIncident {
  id           Int                    @id @default(autoincrement())
  userId       Int
  severity     AuditSeverity          @default(WARNING)
  reason       String
  status       SecurityIncidentStatus @default(OPEN)
  actionTaken  String?
  metadata     Json?
  detectedAt   DateTime               @default(now())
  resolvedAt   DateTime?
  resolvedById Int?
  resolutionNote String?

  user       User  @relation("SecurityIncidentUser", fields: [userId], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("SecurityIncidentResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([userId, detectedAt(sort: Desc)])
  @@index([status])
  @@index([severity])
}

enum ProductModerationCaseStatus {
  OPEN
  SELLER_SUBMITTED
  UNDER_REVIEW
  APPROVED_RESTORED
  REJECTED_UPHELD
  CLOSED
}

model ProductModerationCase {
  id            Int                         @id @default(autoincrement())
  productId     Int
  sellerId      Int?
  status        ProductModerationCaseStatus @default(OPEN)
  violationType String?
  reason        String
  adminNote     String?
  sellerNote    String?
  evidence      Json?
  reviewedById  Int?
  resolvedAt    DateTime?

  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  seller     User?   @relation("ProductModerationSeller", fields: [sellerId], references: [id], onDelete: SetNull)
  reviewedBy User?   @relation("ProductModerationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

enum NotificationType {
  ORDER_UPDATE
  PAYMENT_UPDATE
  RETURN_UPDATE
  REFUND_UPDATE
  PROMOTION
  SYSTEM
  CHAT
  PRODUCT_BANNED
  SUPPORT_TICKET
}


model Notification {
  id       Int              @id @default(autoincrement())
  userId   Int
  title    String
  content  String
  type     NotificationType
  isRead   Boolean          @default(false)
  metadata Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

model ShopFollower {
  id     Int @id @default(autoincrement())
  userId Int
  shopId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, shopId])
  @@index([shopId])
}

model Shipment {
  id             Int       @id @default(autoincrement())
  orderId        Int       @unique
  carrier        String?
  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  status         String

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events ShipmentEvent[]

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([trackingNumber])
}

model ShipmentEvent {
  id         Int      @id @default(autoincrement())
  shipmentId Int
  orderId    Int
  status     String
  message    String?
  location   String?
  metadata   Json?
  occurredAt DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([shipmentId, occurredAt(sort: Desc)])
  @@index([orderId, occurredAt(sort: Desc)])
  @@index([status])
}

model SellerPayout {
  id          Int          @id @default(autoincrement())
  shopId      Int
  amount      Float
  status      PayoutStatus @default(PENDING)
  periodStart DateTime?
  periodEnd   DateTime?
  paidAt      DateTime?
  reviewedAt  DateTime?
  reviewedById Int?
  note        String?

  shop       Shop  @relation(fields: [shopId], references: [id])
  reviewedBy User? @relation("SellerPayoutReviewedBy", fields: [reviewedById], references: [id])

  createdAt DateTime @default(now())

  @@index([shopId])
  @@index([status])
  @@index([reviewedById])
}

model SellerApplication {
  id            Int               @id @default(autoincrement())
  userId        Int
  shopName      String
  shopSlug      String?           @unique
  description   String?
  logoUrl       String?
  coverUrl      String?
  businessPhone String?
  businessEmail String?
  taxCode       String?
  identityFullName String?
  identityNumber   String?
  identityFrontUrl String?
  identityBackUrl  String?
  shippingOptions  Json?
  taxInfo          Json?
  addressLine   String?
  ward          String?
  district      String?
  province      String?
  status        ApplicationStatus @default(PENDING)
  note          String?

  reviewedById Int?
  reviewedAt   DateTime?

  user       User  @relation("SellerApplicationUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("SellerApplicationReviewedBy", fields: [reviewedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  NEED_MORE_INFO
}

model CouponRedemption {
  id       Int @id @default(autoincrement())
  couponId Int
  userId   Int
  orderId  Int?

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([couponId, userId])
  @@index([userId])
  @@index([orderId])
}

model FlashSale {
  id        Int             @id @default(autoincrement())
  name      String
  startsAt  DateTime
  endsAt    DateTime
  status    FlashSaleStatus @default(DRAFT)
  items     FlashSaleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, startsAt, endsAt])
}

model FlashSaleItem {
  id            Int  @id @default(autoincrement())
  flashSaleId   Int
  productId     Int
  variantId     Int?
  shopId        Int
  salePrice     Float
  stockLimit    Int?
  soldCount     Int   @default(0)
  purchaseLimit Int?

  flashSale FlashSale       @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  shop      Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([flashSaleId, productId, variantId])
  @@index([productId])
  @@index([shopId])
}

enum FlashSaleStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

model Banner {
  id             Int            @id @default(autoincrement())
  title          String
  subtitle       String?
  imageUrl       String
  mobileImageUrl String?
  redirectUrl    String?
  buttonText     String?
  position       BannerPosition
  layout         String         @default("ONE_THIRD")
  status         BannerStatus   @default(DRAFT)
  priority       Int            @default(0)
  startAt        DateTime?
  endAt          DateTime?

  createdById Int?
  createdBy   User? @relation("BannerCreatedBy", fields: [createdById], references: [id])

  trackings BannerTracking[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([position, status])
  @@index([startAt, endAt])
}

model BannerTracking {
  id        Int          @id @default(autoincrement())
  bannerId  Int
  userId    Int?
  sessionId String?
  action    BannerAction
  createdAt DateTime     @default(now())

  banner Banner @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([bannerId, action])
  @@index([userId])
}

enum BannerPosition {
  HOME_TOP
  HOME_MIDDLE
  HOME_BOTTOM
  CATEGORY_TOP
  PRODUCT_DETAIL
  CATEGORY_PAGE
  SHOP_PAGE
}

enum BannerStatus {
  DRAFT
  ACTIVE
  INACTIVE
  EXPIRED
}

enum BannerAction {
  VIEW
  CLICK
}

model PlatformCommission {
  id          Int  @id @default(autoincrement())
  orderId     Int
  orderItemId Int?
  shopId      Int

  commissionRate   Float
  grossAmount      Float
  commissionAmount Float
  sellerNetAmount  Float

  status CommissionStatus @default(PENDING)
  note   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id])
  shop      Shop       @relation(fields: [shopId], references: [id])

  @@index([orderId])
  @@index([orderItemId])
  @@index([shopId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model ShopCommissionConfig {
  id             Int       @id @default(autoincrement())
  shopId         Int       @unique
  commissionRate Float
  isActive       Boolean   @default(true)
  startAt        DateTime?
  endAt          DateTime?

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CategoryCommissionConfig {
  id             Int     @id @default(autoincrement())
  categoryId     Int     @unique
  commissionRate Float
  isActive       Boolean @default(true)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CommissionStatus {
  PENDING
  EARNED
  SETTLED
  REFUNDED
  CANCELLED
}

model ReturnRequest {
  id           Int          @id @default(autoincrement())
  orderId      Int
  userId       Int
  status       ReturnStatus @default(REQUESTED)
  reason       String
  description  String?
  rejectReason String?
  refundAmount Float?
  reviewedById Int?
  reviewedAt   DateTime?
  gatewayRefundStatus String?
  gatewayRefundTransactionId String?
  gatewayRefundedAt DateTime?

  order      Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user       User  @relation("ReturnRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ReturnReviewedBy", fields: [reviewedById], references: [id])

  items     ReturnItem[]
  evidences ReturnEvidence[]
  inventoryLedgers InventoryLedger[]
  supportTickets   SupportTicket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([userId])
  @@index([status])
}

model ReturnItem {
  id              Int   @id @default(autoincrement())
  returnRequestId Int
  orderItemId     Int
  quantity        Int
  refundAmount    Float

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem     OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
  @@index([orderItemId])
}

model ReturnEvidence {
  id              Int      @id @default(autoincrement())
  returnRequestId Int
  imageUrl        String
  createdAt       DateTime @default(now())

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
}

enum ReturnStatus {
  REQUESTED
  REQUEST_RETURN
  SELLER_REVIEW
  APPROVED
  RETURN_APPROVED
  REJECTED
  RETURN_REJECTED
  CUSTOMER_APPEAL
  ADMIN_REVIEW
  REFUND_APPROVED
  REFUND_REJECTED
  PICKED_UP
  PICKUP_RETURN_IN_TRANSIT
  RECEIVED
  RETURN_RECEIVED
  REFUNDING
  REFUNDED
  CANCELLED
}

enum InventoryLedgerType {
  MANUAL_ADJUSTMENT
  ORDER_DEDUCT
  CANCEL_RESTORE
  RETURN_RESTORE
  PAYMENT_RELEASE
}

model InventoryLedger {
  id              Int                 @id @default(autoincrement())
  shopId          Int
  productId       Int?
  variantId       Int?
  orderId         Int?
  returnRequestId Int?
  actorId         Int?
  type            InventoryLedgerType
  quantityChange  Int
  stockBefore     Int?
  stockAfter      Int?
  reason          String?
  metadata        Json?

  shop          Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product       Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  order         Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  returnRequest ReturnRequest?  @relation(fields: [returnRequestId], references: [id], onDelete: SetNull)
  actor         User?           @relation("InventoryActor", fields: [actorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([shopId, createdAt(sort: Desc)])
  @@index([productId])
  @@index([variantId])
  @@index([orderId])
  @@index([returnRequestId])
  @@index([type])
}

enum SupportTicketStatus {
  OPEN
  WAITING_SELLER
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SupportSenderRole {
  CUSTOMER
  SELLER
  ADMIN
  SYSTEM
}

model SupportTicket {
  id              Int                   @id @default(autoincrement())
  userId          Int
  shopId          Int?
  orderId         Int?
  returnRequestId Int?
  assignedAdminId Int?
  subject         String
  category        String?
  priority        SupportTicketPriority @default(MEDIUM)
  status          SupportTicketStatus   @default(OPEN)

  user          User           @relation("SupportTicketUser", fields: [userId], references: [id], onDelete: Cascade)
  shop          Shop?          @relation(fields: [shopId], references: [id], onDelete: SetNull)
  order         Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  returnRequest ReturnRequest? @relation(fields: [returnRequestId], references: [id], onDelete: SetNull)
  assignedAdmin User?          @relation("SupportTicketAssignee", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  messages      SupportMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([shopId])
  @@index([orderId])
  @@index([returnRequestId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model SupportMessage {
  id            Int               @id @default(autoincrement())
  ticketId      Int
  senderId      Int?
  senderRole    SupportSenderRole
  message       String
  attachmentUrl String?

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User?         @relation("SupportMessageSender", fields: [senderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([ticketId, createdAt(sort: Asc)])
  @@index([senderId])
}

model OrderCancellation {
  id           Int          @id @default(autoincrement())
  orderId      Int          @unique
  cancelledBy  CancelledBy
  reason       String
  note         String?
  status       CancelStatus @default(CANCELLED)
  refundAmount Float?
  cancelledAt  DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([cancelledBy])
  @@index([cancelledAt(sort: Desc)])
}

enum CancelledBy {
  CUSTOMER
  SELLER
  ADMIN
  SYSTEM
}

enum CancelStatus {
  REQUESTED
  APPROVED
  REJECTED
  CANCELLED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}
