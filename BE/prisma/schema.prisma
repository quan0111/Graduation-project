generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  fullName  String?
  phone     String?
  avatarUrl String?
  role      UserRole @default(CUSTOMER)
  isActive  Boolean  @default(true)

  addresses                  Address[]
  shops                      Shop?
  orders                     Order[]
  reviews                    Review[]
  behaviors                  UserBehavior[]
  carts                      Cart?
  recommendations            Recommendation[]
  notifications              Notification[]
  refreshTokens              RefreshToken[]
  shopFollowers              ShopFollower[]
  bannerTrackings            BannerTracking[]
  sellerApplications         SellerApplication[] @relation("SellerApplicationUser")
  reviewedSellerApplications SellerApplication[] @relation("SellerApplicationReviewedBy")
  returnRequests             ReturnRequest[]     @relation("ReturnRequestUser")
  reviewedReturns            ReturnRequest[]     @relation("ReturnReviewedBy")
  createdBanners             Banner[]            @relation("BannerCreatedBy")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
}

enum UserRole {
  ADMIN
  SELLER
  CUSTOMER
}

model Address {
  id          Int         @id @default(autoincrement())
  userId      Int
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String
  phone       String
  addressLine String
  ward        String?
  district    String
  province    String
  country     String      @default("Vietnam")
  postalCode  String?
  isDefault   Boolean     @default(false)
  type        AddressType @default(HOME)

  orders Order[] @relation("ShippingAddress")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
}

enum AddressType {
  HOME
  OFFICE
  OTHER
}

model Shop {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String? @unique
  description String?
  avatarUrl   String?
  ownerId     Int     @unique
  owner       User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  followers        ShopFollower[]
  products         Product[]
  orders           Order[]
  payouts          SellerPayout[]
  commissions      PlatformCommission[]
  commissionConfig ShopCommissionConfig?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
  @@index([ownerId])
}

model Category {
  id               Int                       @id @default(autoincrement())
  name             String
  slug             String?                   @unique
  parentId         Int?
  parent           Category?                 @relation("CategoryTree", fields: [parentId], references: [id])
  children         Category[]                @relation("CategoryTree")
  products         Product[]
  commissionConfig CategoryCommissionConfig?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
  @@index([parentId])
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  BANNED
  REJECT
  APROVAL
}

model Product {
  id          Int           @id @default(autoincrement())
  name        String
  slug        String?       @unique
  description String?
  price       Float
  shopId      Int
  categoryId  Int
  status      ProductStatus @default(DRAFT)

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  variants   ProductVariant[]
  images     ProductImage[]
  reviews    Review[]
  orderItems OrderItem[]
  behaviors  UserBehavior[]
  cartItems  CartItem[]
  attributes ProductAttribute[]
  tags       Tag[]              @relation("ProductTags")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
  @@index([categoryId])
  @@index([shopId])
  @@index([name])
}

model ProductVariant {
  id        Int     @id @default(autoincrement())
  sku       String? @unique
  name      String
  stock     Int
  weight    Float?
  productId Int
  price     Float

  product    Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  images     VariantImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String
  position  Int     @default(0)
  isPrimary Boolean @default(false)
  productId Int

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model VariantImage {
  id        Int    @id @default(autoincrement())
  url       String
  position  Int    @default(0)
  variantId Int

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model Cart {
  id     Int @id @default(autoincrement())
  userId Int @unique

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        Int  @id @default(autoincrement())
  cartId    Int
  productId Int
  variantId Int?
  quantity  Int

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
}

model Order {
  id             Int         @id @default(autoincrement())
  userId         Int
  shopId         Int
  status         OrderStatus @default(PENDING)
  subtotal       Float
  shippingFee    Float       @default(0)
  discountAmount Float       @default(0)
  totalAmount    Float

  shippingAddressId Int?
  couponId          Int?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shippingAddress Address? @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  coupon          Coupon?  @relation(fields: [couponId], references: [id])

  items          OrderItem[]
  payment        Payment?
  shipment       Shipment?
  cancellation   OrderCancellation?
  returnRequests ReturnRequest[]
  commissions    PlatformCommission[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([shopId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  PROCESSING
  READY_TO_SHIP
  SHIPPED
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
  RETURN_REQUESTED
  RETURNED
}

model OrderItem {
  id           Int     @id @default(autoincrement())
  orderId      Int
  productId    Int
  variantId    Int?
  quantity     Int
  price        Float
  productName  String
  variantName  String?
  productImage String?

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  returnItems ReturnItem[]
  commissions PlatformCommission[]

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model Payment {
  id      Int           @id @default(autoincrement())
  orderId Int           @unique
  method  PaymentMethod
  status  PaymentStatus @default(PENDING)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

enum PaymentMethod {
  COD
  VNPAY
  STRIPE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model Coupon {
  id               Int          @id @default(autoincrement())
  code             String       @unique
  description      String?
  discountType     DiscountType
  discountValue    Float
  minOrderAmount   Float?
  maxDiscount      Float?
  usageLimit       Int?
  usedCount        Int          @default(0)
  validFrom        DateTime?
  validUntil       DateTime?
  isActive         Boolean      @default(true)
  applicableShopId Int?
  orders           Order[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model Review {
  id                 Int     @id @default(autoincrement())
  rating             Int
  comment            String?
  isVerifiedPurchase Boolean @default(false)
  userId             Int
  productId          Int

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([productId])
  @@index([userId, productId])
}

model UserBehavior {
  id        Int          @id @default(autoincrement())
  userId    Int
  productId Int
  action    BehaviorType
  sessionId String?
  duration  Int?
  metadata  Json?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, action])
  @@index([productId])
}

enum BehaviorType {
  VIEW
  CLICK
  ADD_TO_CART
  PURCHASE
}

model ProductAttribute {
  id        Int       @id @default(autoincrement())
  productId Int
  key       String
  value     String
  deletedAt DateTime?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, key])
}

model Tag {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[] @relation("ProductTags")
}

model Recommendation {
  id          Int      @id @default(autoincrement())
  userId      Int
  sessionId   String?
  recommended Json
  algorithm   String?
  timestamp   DateTime @default(now())
  feedback    Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp(sort: Desc)])
}

enum NotificationType {
  ORDER_UPDATE
  PROMOTION
  SYSTEM
  CHAT
}

model Notification {
  id       Int              @id @default(autoincrement())
  userId   Int
  title    String
  content  String
  type     NotificationType
  isRead   Boolean          @default(false)
  metadata Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

model ShopFollower {
  id     Int @id @default(autoincrement())
  userId Int
  shopId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, shopId])
  @@index([shopId])
}

model Shipment {
  id             Int       @id @default(autoincrement())
  orderId        Int       @unique
  carrier        String?
  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  status         String

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([trackingNumber])
}

model SellerPayout {
  id          Int          @id @default(autoincrement())
  shopId      Int
  amount      Float
  status      PayoutStatus @default(PENDING)
  periodStart DateTime?
  periodEnd   DateTime?
  paidAt      DateTime?
  note        String?

  shop Shop @relation(fields: [shopId], references: [id])

  createdAt DateTime @default(now())

  @@index([shopId])
  @@index([status])
}

model SellerApplication {
  id            Int               @id @default(autoincrement())
  userId        Int
  shopName      String
  shopSlug      String?           @unique
  description   String?
  logoUrl       String?
  coverUrl      String?
  businessPhone String?
  businessEmail String?
  taxCode       String?
  addressLine   String?
  ward          String?
  district      String?
  province      String?
  status        ApplicationStatus @default(PENDING)
  note          String?

  reviewedById Int?
  reviewedAt   DateTime?

  user       User  @relation("SellerApplicationUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("SellerApplicationReviewedBy", fields: [reviewedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  NEED_MORE_INFO
}

model Banner {
  id             Int            @id @default(autoincrement())
  title          String
  subtitle       String?
  imageUrl       String
  mobileImageUrl String?
  redirectUrl    String?
  buttonText     String?
  position       BannerPosition
  status         BannerStatus   @default(DRAFT)
  priority       Int            @default(0)
  startAt        DateTime?
  endAt          DateTime?

  createdById Int?
  createdBy   User? @relation("BannerCreatedBy", fields: [createdById], references: [id])

  trackings BannerTracking[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([position, status])
  @@index([startAt, endAt])
}

model BannerTracking {
  id        Int          @id @default(autoincrement())
  bannerId  Int
  userId    Int?
  sessionId String?
  action    BannerAction
  createdAt DateTime     @default(now())

  banner Banner @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([bannerId, action])
  @@index([userId])
}

enum BannerPosition {
  HOME_TOP
  HOME_MIDDLE
  HOME_BOTTOM
  CATEGORY_PAGE
  SHOP_PAGE
}

enum BannerStatus {
  DRAFT
  ACTIVE
  INACTIVE
  EXPIRED
}

enum BannerAction {
  VIEW
  CLICK
}

model PlatformCommission {
  id          Int  @id @default(autoincrement())
  orderId     Int
  orderItemId Int?
  shopId      Int

  commissionRate   Float
  grossAmount      Float
  commissionAmount Float
  sellerNetAmount  Float

  status CommissionStatus @default(PENDING)
  note   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id])
  shop      Shop       @relation(fields: [shopId], references: [id])

  @@index([orderId])
  @@index([orderItemId])
  @@index([shopId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model ShopCommissionConfig {
  id             Int       @id @default(autoincrement())
  shopId         Int       @unique
  commissionRate Float
  isActive       Boolean   @default(true)
  startAt        DateTime?
  endAt          DateTime?

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CategoryCommissionConfig {
  id             Int     @id @default(autoincrement())
  categoryId     Int     @unique
  commissionRate Float
  isActive       Boolean @default(true)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CommissionStatus {
  PENDING
  EARNED
  SETTLED
  REFUNDED
  CANCELLED
}

model ReturnRequest {
  id           Int          @id @default(autoincrement())
  orderId      Int
  userId       Int
  status       ReturnStatus @default(REQUESTED)
  reason       String
  description  String?
  rejectReason String?
  refundAmount Float?
  reviewedById Int?
  reviewedAt   DateTime?

  order      Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user       User  @relation("ReturnRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ReturnReviewedBy", fields: [reviewedById], references: [id])

  items     ReturnItem[]
  evidences ReturnEvidence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([userId])
  @@index([status])
}

model ReturnItem {
  id              Int   @id @default(autoincrement())
  returnRequestId Int
  orderItemId     Int
  quantity        Int
  refundAmount    Float

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem     OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
  @@index([orderItemId])
}

model ReturnEvidence {
  id              Int      @id @default(autoincrement())
  returnRequestId Int
  imageUrl        String
  createdAt       DateTime @default(now())

  returnRequest ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  PICKED_UP
  RECEIVED
  REFUNDED
  CANCELLED
}

model OrderCancellation {
  id           Int          @id @default(autoincrement())
  orderId      Int          @unique
  cancelledBy  CancelledBy
  reason       String
  note         String?
  status       CancelStatus @default(CANCELLED)
  refundAmount Float?
  cancelledAt  DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([cancelledBy])
  @@index([cancelledAt(sort: Desc)])
}

enum CancelledBy {
  CUSTOMER
  SELLER
  ADMIN
  SYSTEM
}

enum CancelStatus {
  REQUESTED
  APPROVED
  REJECTED
  CANCELLED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}
